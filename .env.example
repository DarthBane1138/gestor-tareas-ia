# Variables usadas por Docker Compose, backend y frontend en desarrollo

# ==============================
# Base de datos (PostgreSQL)
# ==============================
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ==============================
# Puertos expuestos en host
# ==============================
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ==============================
# IDs de usuario/grupo para permisos en contenedores
# ==============================
UID=1000
GID=1000
HOST_UID=1000
HOST_GID=1000

# ==============================
# Backend (Django)
# ==============================
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ==============================
# IA (LangChain + Gemini)
# ==============================
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
